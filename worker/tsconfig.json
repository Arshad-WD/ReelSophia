{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "node",
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "./**/*.ts",
    "../src/lib/**/*.ts",
    "../src/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
